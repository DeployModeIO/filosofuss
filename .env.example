# API key de Zhipu AI (GLM). NO subir este archivo a git.
# Consíguela en https://open.bigmodel.cn/usercenter/apikeys
GLM_API_KEY=

# Modelo a usar para la traducción de citas.
# glm-4.5-flash es el recomendado (tiene cuota gratuita en Zhipu AI).
# glm-4.5 requiere saldo/paquete de pago en la cuenta.
GLM_MODEL=glm-4.5-flash
